# Optional AI fallback for the portfolio assistant.
# The site works fully without these — the local knowledge base is the default
# and is always the trustworthy source. Leave unset for the static GitHub Pages build.

# Enable the optional AI fallback
# VITE_ASSISTANT_AI=true

# Your endpoint: POST { message, lang, system } -> { reply: string }
# VITE_ASSISTANT_AI_ENDPOINT=https://your-endpoint.example/chat
